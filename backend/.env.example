# ── AI Services ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...
GEMINI_API_KEY=

# ── Video Achtergronden ───────────────────────────────────────
KIE_API_KEY=...
PIAPI_KEY=...
HIGGSFIELD_API_KEY=
PEXELS_API_KEY=

# ── Integraties ───────────────────────────────────────────────
VAULTBOOST_URL=http://localhost:3001

# ── Server ────────────────────────────────────────────────────
PORT=3002

# Op Railway: stel in als https://<jouw-app>.up.railway.app
SERVER_BASE_URL=http://localhost:3002

# CORS-origins (kommagescheiden) — voeg je frontend Railway-URL toe
CORS_ORIGINS=http://localhost:5174,http://localhost:3001

# ── Railway Persistent Volume (/data) ─────────────────────────
# Stel DATA_DIR=/data in op Railway — outputs en jobs.json worden hier opgeslagen
DATA_DIR=
# Worden automatisch afgeleid van DATA_DIR. Alleen overschrijven indien nodig:
# OUTPUTS_DIR=/data/outputs
# JOBS_FILE=/data/jobs.json
# BATCHES_FILE=/data/batches.json
